rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net - Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Real-time POS synchronization rules
    match /pos_states/{stateId} {
      // Ensure that synchronization registers can be securely updated
      allow read, write: if true;
    }
  }
}
