{
  "entities": {
    "User": {
      "title": "User",
      "description": "Enterprise employee or staff member credentials and attributes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pin": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Cashier", "Waiter", "Kitchen", "Barista"] },
        "email": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "Category": {
      "title": "Category",
      "description": "POS Menu category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "Individual cafe menu item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "available": { "type": "boolean" },
        "isDrink": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "stationId": { "type": "string" }
      },
      "required": ["id", "name", "categoryId", "price", "available", "isDrink"]
    },
    "Table": {
      "title": "Table",
      "description": "Physical tables in the cafe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tableId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["empty", "ordered", "dirty"] },
        "assignedWaiter": { "type": "string" }
      },
      "required": ["id", "tableId", "name", "status"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "An item inside a finalized user order",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "isDrink": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "required": ["productId", "name", "price", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "An active or archived customer ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "tableId": { "type": "string" },
        "tableName": { "type": "string" },
        "items": { "type": "array" },
        "customerNotes": { "type": "string" },
        "subtotal": { "type": "number" },
        "vatAmount": { "type": "number" },
        "serviceCharge": { "type": "number" },
        "discountAmount": { "type": "number" },
        "grandTotal": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "waiterName": { "type": "string" },
        "cashierName": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentReference": { "type": "string" },
        "amountReceived": { "type": "number" },
        "balanceReturned": { "type": "number" },
        "customerType": { "type": "string", "enum": ["Dine-In", "Takeaway"] },
        "businessDate": { "type": "string" },
        "printedQty": { "type": "object" }
      },
      "required": ["id", "orderNumber", "items", "status", "subtotal", "vatAmount", "grandTotal", "createdAt", "updatedAt", "businessDate"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global settings for the cafe",
      "type": "object",
      "properties": {
        "restaurantName": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "vatPercentage": { "type": "number" },
        "serviceChargePercentage": { "type": "number" }
      },
      "required": ["restaurantName", "currencySymbol", "vatPercentage"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Registered cafe personnel profiles with auth mapping"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Cafeteria food menu divisions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Menu entries of drinks or meals"
    },
    "/tables/{tableId}": {
      "schema": "Table",
      "description": "Configured table areas inside the cafe room layout"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order sheets labeled with temporal business dates"
    },
    "/settings/global": {
      "schema": "SystemSettings",
      "description": "Universal operation parameters of the POS kiosk"
    }
  }
}
